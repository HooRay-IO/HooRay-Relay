AWS_REGION=us-west-2
SAM_STACK_NAME=hooray-prod
DEPLOY_ENVIRONMENT=prod
WORKER_ECR_REPOSITORY=hooray-relay-worker-prod
ECS_SUBNET_IDS=<prod subnet ids>
ECS_SECURITY_GROUP_IDS=<prod security group ids>
ENABLE_ECS_WORKER=true
WORKER_DESIRED_COUNT=1
WORKER_CPU=256
WORKER_MEMORY=512
WORKER_ASSIGN_PUBLIC_IP=ENABLED
SQS_VISIBILITY_TIMEOUT_SECONDS=60
SQS_MAX_RECEIVE_COUNT=4

AWS_REGION=us-west-2
SAM_STACK_NAME=hooray-dev
DEPLOY_ENVIRONMENT=dev
WORKER_ECR_REPOSITORY=hooray-relay-worker-dev
ECS_SUBNET_IDS=<dev subnet ids>
ECS_SECURITY_GROUP_IDS=<dev security group ids>
ENABLE_ECS_WORKER=true
WORKER_DESIRED_COUNT=1
WORKER_CPU=256
WORKER_MEMORY=512
WORKER_ASSIGN_PUBLIC_IP=ENABLED
SQS_VISIBILITY_TIMEOUT_SECONDS=60
SQS_MAX_RECEIVE_COUNT=4

# Uncomment if this were a library crate:
# Cargo.lock

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo

# Environment and secrets
.env
.env.*
!.env.example
.envrc
!.envrc.example

# Logs and runtime dumps
*.log
*.out
*.err

# Windows
Thumbs.db

# Test and coverage artifacts
coverage/
*.profraw
*.profdata

# Generated performance/load-test artifacts (may contain environment snapshots)
artifacts/

